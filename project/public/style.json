{
  "version": 8,
  "name": "KY Noise + Base",
  "sprite": "https://api.maptiler.com/maps/019c5d5d-06b2-70c4-8771-110800224358/sprite?key=VR7FKTd6lXA4PKRQVzfY",
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key=VR7FKTd6lXA4PKRQVzfY",
  "sources": {
    "maptiler_planet": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3/tiles.json?key=VR7FKTd6lXA4PKRQVzfY"
    },
    "ky-noise": {
      "type": "raster",
      "tiles": [
        "https://tiles.arcgis.com/tiles/GfBANWpVjDJnX8Qz/arcgis/rest/services/ky_transportation_noise/MapServer/tile/{z}/{y}/{x}"
      ],
      "tileSize": 256,
      "minzoom": 6,
      "maxzoom": 17
    },
    "noise-polygons": {
      "type": "vector",
      "tiles": [
        "https://tiles.arcgis.com/tiles/GfBANWpVjDJnX8Qz/arcgis/rest/services/ky_noise_polygons/VectorTileServer/tile/{z}/{y}/{x}.pbf"
      ],
      "tileSize": 512,
      "minzoom": 11,
      "maxzoom": 17
    },
    "khc-cemeteries": {
      "type": "vector",
      "tiles": [
        "https://tiles.arcgis.com/tiles/GfBANWpVjDJnX8Qz/arcgis/rest/services/khc_cemeteries/VectorTileServer/tile/{z}/{y}/{x}.pbf"
      ],
      "tileSize": 512,
      "minzoom": 11,
      "maxzoom": 17
    },
    "industrial-sites": {
      "type": "geojson",
      "data": "https://kygisserver.ky.gov/arcgis/rest/services/WGS84WM_Services/Ky_Industrial_Site_Boundaries_WGS84WM/MapServer/0/query?where=1%3D1&outFields=*&f=geojson"
    },
    "ky-mask": {
      "type": "vector",
      "tiles": [
        "https://tiles.arcgis.com/tiles/GfBANWpVjDJnX8Qz/arcgis/rest/services/ky_mask/VectorTileServer/tile/{z}/{y}/{x}.pbf"
      ],
      "tileSize": 512,
      "minzoom": 1,
      "maxzoom": 17
    }
  },

  "layers": [
    {
      "id": "Background",
      "type": "background",
      "paint": { "background-color": "#000014" }
    },
    {
      "id": "Water",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "water",
      "layout": { "visibility": "visible" },
      "paint": {
        "fill-antialias": true,
        "fill-color": "#020a2c"
      },
      "filter": [
        "all",
        ["!=", "brunnel", "tunnel"],
        ["==", "$type", "Polygon"],
        ["!=", "intermittent", 1]
      ]
    },
    {
      "id": "Other border",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "boundary",
      "minzoom": 3,
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#3c0354",
        "line-dasharray": {
          "stops": [
            [7, [1, 1]],
            [8, [1, 2]]
          ]
        },
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          0,
          8,
          0.5,
          10,
          0.75,
          12,
          0.8
        ],
        "line-width": {
          "base": 1.3,
          "stops": [
            [7, 1],
            [8, 1.2],
            [9, 1.6],
            [10, 2]
          ]
        }
      },
      "filter": ["all", ["in", "admin_level", 6], ["==", "maritime", 0]]
    },
    {
      "id": "River",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "waterway",
      "minzoom": 12,
      "layout": { "visibility": "visible" },
      "paint": {
        "line-color": "#020a2c",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          2,
          15,
          2.5,
          20,
          4
        ]
      }
    },
    {
      "id": "KHC cemeteries fill",
      "type": "fill",
      "source": "khc-cemeteries",
      "source-layer": "KHC Cemeteries",
      "minzoom": 11,
      "paint": {
        "fill-color": "#1A2B1F",
        "fill-opacity": 1
      }
    },
    {
      "id": "industrial-sites-fill",
      "type": "fill",
      "source": "industrial-sites",
      "paint": {
        "fill-color": "#feb555",
        "fill-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.05,
          7,
          0.25,
          9,
          0.6,
          10,
          0.8
        ]
      }
    },
    {
      "id": "industrial-glow-mid",
      "type": "line",
      "source": "industrial-sites",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#3b002b",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          4,
          10,
          7,
          14,
          10
        ],
        "line-blur": ["interpolate", ["linear"], ["zoom"], 6, 2, 10, 4, 14, 6],
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.05,
          7,
          0.1,
          9,
          0.2,
          10,
          0.35
        ]
      }
    },
    {
      "id": "industrial-outline-core",
      "type": "line",
      "source": "industrial-sites",
      "layout": {
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#feb555",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          6,
          1.2,
          10,
          1.8,
          14,
          2.6
        ],
        "line-opacity": [
          "interpolate",
          ["linear"],
          ["zoom"],
          5,
          0.05,
          7,
          0.1,
          9,
          0.5,
          10,
          0.8
        ]
      }
    },
    {
      "id": "Road network",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 6,
      "layout": {
        "line-cap": "round",
        "line-join": "round",
        "visibility": "visible"
      },
      "paint": {
        "line-color": [
          "interpolate",
          ["exponential", 1],
          ["zoom"],
          6,
          "#4a464d",
          10,
          "#4a464d",
          16,
          "#4a464d"
        ],
        "line-opacity": 1,
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          7,
          ["match", ["get", "class"], ["motorway", "trunk"], 1, 0],
          10,
          ["match", ["get", "class"], ["motorway", "trunk"], 2, 0],
          12,
          [
            "match",
            ["get", "class"],
            ["motorway", "trunk"],
            3.5,
            "primary",
            0.75,
            0
          ],
          13,
          [
            "match",
            ["get", "class"],
            ["motorway", "trunk"],
            5,
            "primary",
            2.5,
            0.5
          ],
          15,
          ["match", ["get", "class"], "motorway", 7, "primary", 6, 3],
          16,
          [
            "match",
            ["get", "class"],
            ["motorway", "trunk"],
            8,
            "primary",
            7,
            5
          ],
          17,
          ["match", ["get", "class"], ["motorway", "trunk"], 9, 8]
        ]
      },
      "filter": [
        "in",
        "class",
        "motorway",
        "trunk",
        "primary",
        "secondary",
        "tertiary",
        "minor",
        "service",
        "pier"
      ]
    },
    {
      "id": "Railway",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 13,
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#4a464d",
        "line-width": {
          "stops": [
            [13, 0.85],
            [17, 2]
          ]
        }
      },
      "filter": ["==", "class", "rail"]
    },
    {
      "id": "Railway hatching",
      "type": "line",
      "source": "maptiler_planet",
      "source-layer": "transportation",
      "minzoom": 15,
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "line-color": "#4a464d",
        "line-dasharray": {
          "stops": [
            [15, [0.2, 0.8]],
            [17, [0.2, 1]]
          ]
        },
        "line-width": {
          "stops": [
            [15, 2],
            [17, 6]
          ]
        }
      },
      "filter": ["==", "class", "rail"]
    },
    {
      "id": "Building",
      "type": "fill",
      "source": "maptiler_planet",
      "source-layer": "building",
      "minzoom": 16,
      "layout": { "visibility": "visible" },
      "paint": {
        "fill-antialias": true,
        "fill-color": "#000030",
        "fill-opacity": {
          "base": 1,
          "stops": [
            [13, 0],
            [16, 1]
          ]
        },
        "fill-outline-color": "hsl(0, 14%, 0%)"
      }
    },
    {
      "id": "Noise",
      "type": "raster",
      "source": "ky-noise",
      "minzoom": 6,
      "maxzoom": 17,
      "paint": {
        "raster-opacity": 0.8,
        "raster-resampling": "linear"
      }
    },
    {
      "id": "Noise polygons",
      "type": "fill",
      "source": "noise-polygons",
      "source-layer": "noise_raster_polygons",
      "minzoom": 11,
      "maxzoom": 17,
      "paint": {
        "fill-color": "#ffffff",
        "fill-opacity": 0
      }
    },
    {
      "id": "Lake labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "water_name",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "point",
        "symbol-spacing": 350,
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-letter-spacing": 0.1,
        "text-max-width": 6,
        "text-rotation-alignment": "map",
        "text-size": 14,
        "text-transform": "none",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#001c99",
        "text-halo-color": "#010a33",
        "text-halo-width": 4,
        "text-halo-blur": 4
      },
      "filter": ["all", ["==", "class", "lake"], ["has", "name"]]
    },
    {
      "id": "River labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "waterway",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": 200,
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Italic"],
        "text-max-width": 20,
        "text-rotation-alignment": "map",
        "text-size": {
          "stops": [
            [14, 12],
            [18, 19]
          ]
        },
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#001c99",
        "text-halo-color": "#010a33",
        "text-halo-width": 1.5
      },
      "filter": ["has", "name"]
    },
    {
      "id": "Road labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "transportation_name",
      "minzoom": 10,
      "layout": {
        "symbol-placement": "line",
        "symbol-spacing": [
          "interpolate",
          ["linear"],
          ["zoom"],
          20,
          250,
          22,
          600
        ],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Noto Sans Bold"],
        "text-rotation-alignment": "map",
        "text-size": ["interpolate", ["linear"], ["zoom"], 13, 12, 14, 13],
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2
      },
      "filter": [
        "in",
        "class",
        "primary",
        "secondary",
        "tertiary",
        "trunk",
        "minor",
        "service",
        "track"
      ]
    },
    {
      "id": "Place labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place",
      "minzoom": 12,
      "layout": {
        "symbol-sort-key": ["to-number", ["get", "rank"]],
        "text-anchor": "center",
        "text-field": "{name}",
        "text-font": ["Nunito Semi Bold", "Noto Sans Regular"],
        "text-letter-spacing": [
          "match",
          ["get", "class"],
          ["suburb", "neighborhood", "neighbourhood", "quarter", "island"],
          0.2,
          0
        ],
        "text-max-width": ["match", ["get", "class"], ["island"], 6, 8],
        "text-size": [
          "interpolate",
          ["linear", 1],
          ["zoom"],
          12,
          [
            "match",
            ["get", "class"],
            [
              "suburb",
              "neighbourhood",
              "quarter",
              "hamlet",
              "isolated_dwelling"
            ],
            9,
            "island",
            8,
            12
          ],
          16,
          [
            "match",
            ["get", "class"],
            [
              "suburb",
              "neighbourhood",
              "quarter",
              "hamlet",
              "isolated_dwelling"
            ],
            15,
            "island",
            11,
            16
          ]
        ],
        "text-transform": [
          "match",
          ["get", "class"],
          ["suburb", "neighborhood", "neighbourhood", "quarter", "island"],
          "uppercase",
          "none"
        ],
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2
      },
      "filter": [
        "!in",
        "class",
        "continent",
        "country",
        "state",
        "region",
        "province",
        "city",
        "town",
        "village",
        "place"
      ]
    },
    {
      "id": "Town labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place",
      "minzoom": 10,
      "maxzoom": 16,
      "layout": {
        "symbol-sort-key": ["to-number", ["get", "rank"]],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Nunito Bold", "Noto Sans Bold"],
        "text-max-width": 10,
        "text-size": {
          "stops": [
            [8, 15],
            [16, 18]
          ]
        },
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2
      },
      "filter": ["==", "class", "town"]
    },
    {
      "id": "State labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place",
      "minzoom": 4,
      "maxzoom": 10,
      "layout": {
        "symbol-sort-key": ["to-number", ["get", "rank"]],
        "text-field": ["coalesce", ["get", "name:en"], ["get", "name"]],
        "text-font": ["Nunito Semi Bold"],
        "text-max-width": 10,
        "text-size": {
          "stops": [
            [3, 8],
            [10, 14]
          ]
        },
        "text-transform": "uppercase",
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2,
        "text-opacity": [
          "step",
          ["zoom"],
          0,
          4,
          ["case", ["<=", ["get", "rank"], 3], 1, 0],
          8,
          ["case", ["==", ["get", "rank"], 0], 0, 1]
        ]
      },
      "filter": ["all", ["in", "class", "state", "province"], ["<=", "rank", 6]]
    },
    {
      "id": "City labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place",
      "minzoom": 5,
      "maxzoom": 16,
      "layout": {
        "symbol-sort-key": ["to-number", ["get", "rank"]],
        "text-field": "{name:en}",
        "text-font": ["Nunito Bold", "Noto Sans Bold"],
        "text-max-width": 10,
        "text-size": [
          "interpolate",
          ["linear", 1],
          ["zoom"],
          5,
          ["case", ["==", ["get", "capital"], 2], 16, 12],
          7,
          ["case", ["==", ["get", "capital"], 2], 18, 14],
          9,
          ["case", ["==", ["get", "capital"], 2], 25, 22],
          11,
          ["case", ["==", ["get", "capital"], 2], 28, 24]
        ],
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2
      },
      "filter": [
        "all",
        ["==", "class", "city"],
        [
          "!in",
          "name",
          "Cincinnati",
          "Paducah",
          "Louisville",
          "Maysville",
          "Henderson",
          "Ashland",
          "Portsmouth",
          "Huntington",
          "Evansville",
          "Jeffersonville",
          "Williamson",
          "Owensboro"
        ]
      ]
    },
    {
      "id": "mask",
      "type": "fill",
      "source": "ky-mask",
      "source-layer": "KY_erase",
      "minzoom": 1,
      "layout": {
        "visibility": "visible"
      },
      "paint": {
        "fill-color": "#000014",
        "fill-opacity": 1
      }
    },
    {
      "id": "mask-outline",
      "type": "line",
      "source": "ky-mask",
      "source-layer": "KY_erase",
      "layout": {
        "visibility": "visible",
        "line-join": "round",
        "line-cap": "round"
      },
      "paint": {
        "line-color": "#3c0354",
        "line-width": ["interpolate", ["linear"], ["zoom"], 5, 1, 10, 2, 15, 3],
        "line-blur": 1,
        "line-opacity": 1
      }
    },
    {
      "id": "Bordern city labels",
      "type": "symbol",
      "source": "maptiler_planet",
      "source-layer": "place",
      "minzoom": 5,
      "maxzoom": 16,
      "layout": {
        "symbol-sort-key": ["to-number", ["get", "rank"]],
        "text-field": "{name:en}",
        "text-font": ["Nunito Bold", "Noto Sans Bold"],
        "text-max-width": 10,
        "text-size": [
          "interpolate",
          ["linear", 1],
          ["zoom"],
          5,
          ["case", ["==", ["get", "capital"], 2], 16, 12],
          7,
          ["case", ["==", ["get", "capital"], 2], 18, 14],
          9,
          ["case", ["==", ["get", "capital"], 2], 25, 22],
          11,
          ["case", ["==", ["get", "capital"], 2], 28, 24]
        ],
        "visibility": "visible"
      },
      "paint": {
        "text-color": "#ffd166",
        "text-halo-color": "#3b002b",
        "text-halo-width": 2.5,
        "text-halo-blur": 1.2
      },
      "filter": [
        "all",
        ["==", "class", "city"],
        [
          "in",
          "name",
          "Cincinnati",
          "Paducah",
          "Louisville",
          "Maysville",
          "Henderson",
          "Ashland",
          "Owensboro"
        ]
      ]
    }
  ]
}
